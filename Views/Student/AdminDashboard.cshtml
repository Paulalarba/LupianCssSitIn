        // Render checked-in students
        function renderOngoingSitInsTable() {
            const tbody = document.getElementById('sitin-ongoing-tbody');
            tbody.innerHTML = '';

            if (ongoingSitIns.length === 0) {
                tbody.innerHTML = `<tr><td colspan="7" style="text-align: center; color: var(--text-muted); padding: 2rem;">No students are currently checked into computer laboratories.</td></tr>`;
                document.getElementById('stats-active-sitins-count').textContent = "0 Students Live";
                return;
            }

            document.getElementById('stats-active-sitins-count').textContent = `${ongoingSitIns.length} Student${ongoingSitIns.length > 1 ? 's' : ''} Live`;

            ongoingSitIns.forEach(s => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td><strong>${s.studentId}</strong></td>
                    <td>${s.studentName}</td>
                    <td>Lab Room ${s.labRoom}</td>
                    <td><strong>PC #${s.pcNumber}</strong></td>
                    <td>${s.checkInTime}</td>
                    <td><span class="badge-status pending" style="font-size: 0.7rem; font-weight: 500;">${s.purpose}</span></td>
                    <td><button class="btn-action-sm danger" onclick="checkOutStudent('${s.studentId}')">🚪 Check-Out</button></td>
                `;
                tbody.appendChild(tr);
            });
        }

        // Check out student (Automatic remaining session deduction + award loyalty points gamified)
        function checkOutStudent(studentId) {
            const index = ongoingSitIns.findIndex(s => s.studentId === studentId);
            if (index === -1) return;

            const session = ongoingSitIns[index];

            if (confirm(`Check-out student ${session.studentName}? This will deduct 1 session and award them +20 rewards points.`)) {
                // Deduct session
                const currentSessions = parseInt(localStorage.getItem(`sess_${studentId}`)) || 30;
                const nextSessions = Math.max(0, currentSessions - 1);
                localStorage.setItem(`sess_${studentId}`, nextSessions.toString());

                // Award points
                const currentPoints = parseInt(localStorage.getItem(`pts_${studentId}`)) || 0;
                localStorage.setItem(`pts_${studentId}`, (currentPoints + 20).toString());

                // Log to Sit In History
                const checkOutTime = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                const dateStr = new Date().toISOString().split('T')[0];

                const logEntry = {
                    studentId: session.studentId,
                    studentName: session.studentName,
                    labRoom: session.labRoom,
                    pcNumber: session.pcNumber,
                    checkInTime: `${dateStr} ${session.checkInTime}`,
                    checkOutTime: `${dateStr} ${checkOutTime}`,
                    purpose: session.purpose
                };

                sitInHistory.unshift(logEntry); // Insert at top
                localStorage.setItem('admin_sitin_history', JSON.stringify(sitInHistory));

                // Log points transaction
                const newReward = {
                    id: "RE-" + Math.floor(Math.random() * 900 + 100),
                    studentId: session.studentId,
                    studentName: session.studentName,
                    amount: 20,
                    type: "Lab Work",
                    desc: `Completed checked laboratory sit-in session at Lab Room ${session.labRoom}`,
                    date: "Just Now"
                };
                rewardPointsLog.unshift(newReward);
                localStorage.setItem('admin_reward_logs', JSON.stringify(rewardPointsLog));

                // Remove from ongoing
                ongoingSitIns.splice(index, 1);
                localStorage.setItem('admin_ongoing_sitins', JSON.stringify(ongoingSitIns));

                // Refresh everything
                renderOngoingSitInsTable();
                renderSitInHistoryTable();
                renderRecentRewardsLog();
                updateDashboardStatistics();
                renderLeaderboard();
                renderStudentDatabaseTable(dbStudents);

                alert(`Checked out ${session.studentName}. Remaining Sessions: ${nextSessions}. Reward points awarded!`);
            }
        }

