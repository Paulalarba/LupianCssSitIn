        // Render Feedback
        function renderFeedback() {
            const categoryFilter = document.getElementById('feedback-filter-category').value;
            const tbody = document.getElementById('feedback-table-tbody');
            tbody.innerHTML = '';

            let logs = feedbackLogs;
            if (categoryFilter) {
                logs = logs.filter(f => f.category === categoryFilter);
            }

            if (logs.length === 0) {
                tbody.innerHTML = `<tr><td colspan="8" style="text-align: center; color: var(--text-muted); padding: 2rem;">No feedback matched selected category.</td></tr>`;
                return;
            }

            logs.forEach(f => {
                const stars = "★".repeat(f.rating) + "☆".repeat(5 - f.rating);
                let badgeClass = f.status === 'Reviewed' ? 'active' : 'pending';
                const actionHtml = f.status === 'Pending' ? `<button class="btn-action-sm primary" onclick="markFeedbackReviewed('${f.subject}')">✓ Mark Reviewed</button>` : `<span style="font-size:0.75rem; color:var(--text-muted);">Resolved</span>`;

                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>${f.date}</td>
                    <td><strong>${f.studentName}</strong></td>
                    <td><span class="stat-badge" style="background: rgba(59, 130, 246, 0.1); color: var(--info-blue);">${f.category}</span></td>
                    <td><strong>${f.subject}</strong></td>
                    <td><p style="max-width: 250px; white-space: normal; overflow: hidden; text-overflow: ellipsis; font-size:0.75rem; line-height: 1.3;">${f.message}</p></td>
                    <td><span style="color: var(--accent-yellow); font-size:0.95rem;">${stars}</span></td>
                    <td><span class="badge-status ${badgeClass}">${f.status}</span></td>
                    <td>${actionHtml}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        function markFeedbackReviewed(subject) {
            const index = feedbackLogs.findIndex(f => f.subject === subject);
            if (index === -1) return;

            feedbackLogs[index].status = 'Reviewed';
            localStorage.setItem('admin_feedbacks', JSON.stringify(feedbackLogs));
            renderFeedback();
            alert('Feedback updated to Reviewed status.');
        }

