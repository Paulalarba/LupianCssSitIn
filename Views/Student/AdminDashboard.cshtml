@{
    Layout = null;
    ViewData["Title"] = "Admin Dashboard";
    string adminName = "System Administrator";
    string initials = "AD";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary-blue: oklch(38% 0.12 258);
            --primary-dark: oklch(29% 0.11 258);
            --accent-yellow: oklch(78% 0.14 82);
            --light-bg: oklch(97% 0.01 250);
            --card-bg: oklch(100% 0.004 250);
            --text-dark: oklch(24% 0.035 250);
            --text-muted: oklch(48% 0.032 250);
            --border-light: oklch(89% 0.018 250);
            --success-green: oklch(58% 0.13 154);
            --warning-orange: oklch(72% 0.14 72);
            --danger-red: oklch(57% 0.18 27);
            --info-blue: oklch(59% 0.14 244);
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background-color: var(--light-bg);
            color: var(--text-dark);
            overflow-x: hidden;
        }

        .dashboard-container {
            display: flex;
            min-height: 100vh;
        }

        /* SIDEBAR STYLE (Identical to Student Dashboard) */
        .sidebar {
            width: 280px;
            background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-dark) 100%);
            color: white;
            padding: 2rem 1.5rem;
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            overflow-y: auto;
            box-shadow: 0 10px 40px rgba(15, 61, 145, 0.2);
            z-index: 1000;
        }

        .sidebar-logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 2rem;
            padding-bottom: 2rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .sidebar-logo-icon {
            width: 40px;
            height: 40px;
            background: var(--accent-yellow);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            color: var(--primary-blue);
            font-size: 1.2rem;
        }

        .sidebar-logo-text h3 {
            font-size: 0.95rem;
            font-weight: 700;
            line-height: 1;
            margin-bottom: 0.2rem;
        }

        .sidebar-logo-text p {
            font-size: 0.7rem;
            color: rgba(255, 255, 255, 0.7);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .sidebar-menu {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            margin-bottom: 2rem;
        }

        .sidebar-section {
            margin-bottom: 1.25rem;
        }

        .sidebar-section-title {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: rgba(255, 255, 255, 0.5);
            margin-bottom: 0.5rem;
            font-weight: 600;
        }

        .sidebar-menu-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1rem;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
            color: rgba(255, 255, 255, 0.8);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 500;
        }

        .sidebar-menu-item:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            transform: translateX(4px);
        }

        .sidebar-menu-item.active {
            background: var(--accent-yellow);
            color: var(--primary-blue);
            font-weight: 600;
        }

        .sidebar-menu-item .icon {
            width: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
        }

        .sidebar-menu-item .badge {
            margin-left: auto;
            background: var(--danger-red);
            color: white;
            border-radius: 50%;
            padding: 0.2rem 0.5rem;
            font-size: 0.7rem;
            font-weight: 700;
        }

        .sidebar-profile {
            padding-top: 1.5rem;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            gap: 1rem;
            align-items: center;
        }

        .sidebar-profile-avatar {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: var(--accent-yellow);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: var(--primary-blue);
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .sidebar-profile-info {
            flex: 1;
            min-width: 0;
        }

        .sidebar-profile-info p:first-child {
            font-size: 0.85rem;
            font-weight: 600;
            margin: 0;
            color: white;
        }

        .sidebar-profile-info p:last-child {
            font-size: 0.75rem;
            color: rgba(255, 255, 255, 0.6);
            margin: 0;
        }

        /* MAIN CONTENT & TOP NAVBAR (Identical to Student Dashboard) */
        .main-content {
            flex: 1;
            margin-left: 280px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .top-navbar {
            background: var(--card-bg);
            border-bottom: 1px solid var(--border-light);
            padding: 1rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
            position: sticky;
            top: 0;
            z-index: 99;
        }

        .navbar-left {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            flex: 1;
        }

        .navbar-title {
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--text-dark);
        }

        .navbar-right {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .navbar-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
            background: var(--light-bg);
            color: var(--text-muted);
            font-size: 1.2rem;
            position: relative;
        }

        .navbar-icon:hover {
            background: var(--primary-blue);
            color: white;
        }

        .navbar-icon.notification::after {
            content: '3';
            position: absolute;
            top: -5px;
            right: -5px;
            background: var(--danger-red);
            color: white;
            border-radius: 50%;
            width: 18px;
            height: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.65rem;
            font-weight: 700;
        }

        .navbar-user {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.5rem 1rem;
            cursor: pointer;
            border-radius: 10px;
            transition: all 0.3s ease;
        }

        .navbar-user:hover {
            background: var(--light-bg);
        }

        .navbar-user-avatar {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--accent-yellow), oklch(86% 0.13 84));
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: var(--primary-blue);
            font-size: 1rem;
        }

        .navbar-user-name {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text-dark);
        }

        .btn-logout {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger-red);
            border: 1px solid rgba(239, 68, 68, 0.2);
            padding: 0.5rem 1rem;
            font-size: 0.8rem;
            font-weight: 600;
            border-radius: 8px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.3s ease;
        }

        .btn-logout:hover {
            background: var(--danger-red);
            color: white;
        }

        /* CONTENT STYLING (Identical to Student Dashboard) */
        .dashboard-content {
            flex: 1;
            padding: 2rem;
            overflow-y: auto;
        }

        .welcome-banner {
            background: linear-gradient(135deg, var(--primary-blue) 0%, oklch(45% 0.13 248) 100%);
            border-radius: 16px;
            padding: 2rem;
            margin-bottom: 2rem;
            color: white;
            position: relative;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(15, 61, 145, 0.15);
        }

        .welcome-banner::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
            border-radius: 50%;
        }

        .welcome-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: relative;
            z-index: 1;
        }

        .welcome-text h1 {
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .welcome-text p {
            font-size: 0.9rem;
            color: rgba(255, 255, 255, 0.9);
            margin-bottom: 1.2rem;
        }

        .welcome-badges {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .welcome-badge {
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            padding: 0.5rem 1rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 500;
        }

        .welcome-badge strong {
            color: var(--accent-yellow);
            font-weight: 700;
        }

        .welcome-date {
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 16px;
            padding: 1.5rem;
            text-align: center;
            min-width: 140px;
        }

        .welcome-date-day {
            font-size: 2rem;
            font-weight: 800;
            line-height: 1;
        }

        .welcome-date-month {
            font-size: 0.9rem;
            margin-top: 0.5rem;
            color: rgba(255, 255, 255, 0.9);
        }

        .welcome-date-year {
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.7);
            margin-top: 0.25rem;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: var(--card-bg);
            border-radius: 16px;
            padding: 2rem;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
            border: 1px solid var(--border-light);
            transition: all 0.3s ease;
        }

        .stat-card:hover {
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
            border-color: var(--primary-blue);
            transform: translateY(-4px);
        }

        .stat-card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1.5rem;
        }

        .stat-card-title {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
            font-weight: 600;
        }

        .stat-card-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            background: var(--light-bg);
        }

        .stat-card-value {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--text-dark);
            margin-bottom: 0.5rem;
        }

        .stat-card-subtitle {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-bottom: 1rem;
        }

        .progress-bar {
            width: 100%;
            height: 8px;
            background: var(--light-bg);
            border-radius: 10px;
            overflow: hidden;
            margin-bottom: 0.75rem;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--primary-blue), var(--info-blue));
            border-radius: 10px;
            transition: width 0.3s ease;
        }

        .progress-text {
            display: flex;
            justify-content: space-between;
            font-size: 0.75rem;
            color: var(--text-muted);
            font-weight: 500;
        }

        .stat-badge {
            display: inline-block;
            background: var(--accent-yellow);
            color: var(--primary-blue);
            padding: 0.3rem 0.8rem;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        /* CARDS & TABLES */
        .dashboard-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 2rem;
            margin-bottom: 2rem;
        }

        .dashboard-card {
            background: var(--card-bg);
            border-radius: 16px;
            padding: 2rem;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
            border: 1px solid var(--border-light);
            margin-bottom: 2rem;
        }

        .dashboard-card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            border-bottom: 1px solid var(--border-light);
            padding-bottom: 1rem;
        }

        .dashboard-card-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text-dark);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .table-container {
            width: 100%;
            overflow-x: auto;
            border-radius: 10px;
            border: 1px solid var(--border-light);
        }

        .custom-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
            font-size: 0.85rem;
        }

        .custom-table th {
            background-color: var(--light-bg);
            color: var(--text-muted);
            font-weight: 600;
            padding: 1rem;
            border-bottom: 1px solid var(--border-light);
        }

        .custom-table td {
            padding: 1rem;
            border-bottom: 1px solid var(--border-light);
            color: var(--text-dark);
            vertical-align: middle;
        }

        .custom-table tr:last-child td {
            border-bottom: none;
        }

        .custom-table tr:hover {
            background-color: rgba(245, 247, 251, 0.5);
        }

        /* FORMS & ACTIONS */
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .form-group {
            margin-bottom: 1.25rem;
        }

        .form-group label {
            display: block;
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--text-dark);
            margin-bottom: 0.4rem;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 0.75rem;
            border: 1px solid var(--border-light);
            border-radius: 8px;
            font-size: 0.85rem;
            font-family: inherit;
            color: var(--text-dark);
            transition: all 0.3s ease;
            background-color: white;
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: var(--primary-blue);
            box-shadow: 0 0 0 3px rgba(15, 61, 145, 0.1);
        }

        .form-group input[readonly] {
            background-color: var(--light-bg);
            cursor: not-allowed;
        }

        /* BADGES */
        .badge-status {
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 700;
            display: inline-block;
        }

        .badge-status.active {
            background-color: rgba(16, 185, 129, 0.15);
            color: var(--success-green);
        }

        .badge-status.pending {
            background-color: rgba(245, 158, 11, 0.15);
            color: var(--warning-orange);
        }

        .badge-status.ended {
            background-color: var(--border-light);
            color: var(--text-muted);
        }

        /* TAB MANAGEMENT */
        .tab-pane {
            display: none;
            animation: fadeIn 0.4s ease;
        }

        .tab-pane.active {
            display: block;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(5px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* CUSTOM UTILITIES */
        .btn-action-sm {
            padding: 0.4rem 0.8rem;
            font-size: 0.75rem;
            font-weight: 600;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-right: 0.25rem;
        }

        .btn-action-sm.primary {
            background-color: var(--primary-blue);
            color: white;
        }

        .btn-action-sm.primary:hover {
            background-color: var(--primary-dark);
        }

        .btn-action-sm.success {
            background-color: var(--success-green);
            color: white;
        }

        .btn-action-sm.success:hover {
            opacity: 0.9;
        }

        .btn-action-sm.danger {
            background-color: var(--danger-red);
            color: white;
        }

        .btn-action-sm.danger:hover {
            opacity: 0.9;
        }

        .btn-action-sm.secondary {
            background-color: var(--light-bg);
            color: var(--text-dark);
            border: 1px solid var(--border-light);
        }

        .btn-action-sm.secondary:hover {
            background-color: var(--border-light);
        }

        /* ANALYTICS CHARTS CSS/SVG */
        .analytics-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            margin-bottom: 2rem;
        }

        .bar-chart-container {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            height: 180px;
            gap: 1rem;
            margin-top: 1rem;
        }

        .chart-bar-vertical {
            flex: 1;
            background: linear-gradient(180deg, var(--primary-blue), #3b82f6);
            border-radius: 6px 6px 0 0;
            min-height: 10px;
            position: relative;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .chart-bar-vertical:hover {
            background: var(--accent-yellow);
        }

        .chart-bar-vertical::after {
            content: attr(data-value);
            position: absolute;
            top: -20px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 0.65rem;
            font-weight: 700;
            color: var(--text-dark);
        }

        /* MODAL OVERLAYS (Identical to Student Dashboard) */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            z-index: 2000;
            animation: fadeIn 0.3s ease;
        }

        .modal-overlay.active {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background: var(--card-bg);
            border-radius: 16px;
            padding: 2rem;
            max-width: 600px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            animation: slideIn 0.3s ease;
            position: relative;
        }

        @@keyframes slideIn {
            from { transform: scale(0.95); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--border-light);
        }

        .modal-title {
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--text-dark);
        }

        .modal-close-btn {
            background: none;
            border: none;
            font-size: 1.5rem;
            cursor: pointer;
            color: var(--text-muted);
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        .modal-close-btn:hover {
            background: var(--light-bg);
            color: var(--text-dark);
        }

        .modal-body {
            margin-bottom: 1.5rem;
        }

        .modal-footer {
            display: flex;
            gap: 1rem;
            justify-content: flex-end;
            padding-top: 1rem;
            border-top: 1px solid var(--border-light);
        }

        /* SCROLLBARS */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-track {
            background: var(--light-bg);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--primary-blue);
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--primary-dark);
        }

        /* PRINT MEDIA FOR HIGH FIDELITY PDF REPORTS */
        @@media print {
            body * {
                visibility: hidden;
            }
            #print-report-container, #print-report-container * {
                visibility: visible;
            }
            #print-report-container {
                position: absolute;
                left: 0;
                top: 0;
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <!-- SIDEBAR (CCS Admin layout matching Student portal) -->
        <aside class="sidebar">
            <div class="sidebar-logo">
                <div class="sidebar-logo-icon">🎓</div>
                <div class="sidebar-logo-text">
                    <h3>CCS Admin</h3>
                    <p>Management Portal</p>
                </div>
            </div>

            <nav class="sidebar-menu">
                <div class="sidebar-section">
                    <div class="sidebar-section-title">Overview</div>
                    <a href="#" class="sidebar-menu-item active" data-tab="tab-dashboard">
                        <span class="icon">📊</span>
                        <span>Dashboard Analytics</span>
                    </a>
                </div>

                <div class="sidebar-section">
                    <div class="sidebar-section-title">Students</div>
                    <a href="#" class="sidebar-menu-item" data-tab="tab-students">
                        <span class="icon">👥</span>
                        <span>Students Information</span>
                    </a>
                    <a href="#" class="sidebar-menu-item" data-tab="tab-rewards">
                        <span class="icon">⭐</span>
                        <span>Points & Rewards</span>
                    </a>
                </div>

                <div class="sidebar-section">
                    <div class="sidebar-section-title">Sit-In Operations</div>
