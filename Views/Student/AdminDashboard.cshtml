        // Render Reservations Approve / Reject
        function renderReservationsTable() {
            const tbody = document.getElementById('reservations-table-tbody');
            tbody.innerHTML = '';

            if (reservations.length === 0) {
                tbody.innerHTML = `<tr><td colspan="9" style="text-align: center; color: var(--text-muted); padding: 2rem;">No pending reservations found.</td></tr>`;
                return;
            }

            reservations.forEach(r => {
                const tr = document.createElement('tr');
                let badgeClass = 'pending';
                if (r.status === 'Confirmed') badgeClass = 'active';
                if (r.status === 'Declined') badgeClass = 'ended';

                const actionsHtml = r.status === 'Pending' ? `
                    <button class="btn-action-sm success" onclick="handleReservationAction('${r.id}', 'Confirmed')">✓ Approve</button>
                    <button class="btn-action-sm danger" onclick="handleReservationAction('${r.id}', 'Declined')">✗ Decline</button>
                ` : `<button class="btn-action-sm secondary" onclick="deleteReservation('${r.id}')">🗑️ Delete</button>`;

                tr.innerHTML = `
                    <td><strong>${r.id}</strong></td>
                    <td>${r.studentId}</td>
                    <td>${r.studentName}</td>
                    <td>Room ${r.labRoom}</td>
                    <td>PC #${r.pcNumber}</td>
                    <td>${r.date}</td>
                    <td><span style="font-size: 0.75rem; color: var(--text-muted);">${r.timeSlot}</span></td>
                    <td><span class="badge-status ${badgeClass}">${r.status}</span></td>
                    <td>${actionsHtml}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        function handleReservationAction(resId, status) {
            const index = reservations.findIndex(r => r.id === resId);
            if (index === -1) return;

            reservations[index].status = status;
            localStorage.setItem('admin_reservations', JSON.stringify(reservations));
            
            renderReservationsTable();
            updateDashboardStatistics();
            alert(`Reservation status updated to ${status}.`);
        }

        function deleteReservation(resId) {
            if (confirm('Delete this reservation entry?')) {
                reservations = reservations.filter(r => r.id !== resId);
                localStorage.setItem('admin_reservations', JSON.stringify(reservations));
                renderReservationsTable();
                updateDashboardStatistics();
            }
        }

        // Render Announcements
        function renderAnnouncements() {
            const container = document.getElementById('announcements-list-panel');
