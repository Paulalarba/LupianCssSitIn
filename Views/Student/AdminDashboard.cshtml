        // Fetch students from real DB endpoint on page load
        function fetchStudentsFromDatabase() {
            fetch('/Student/GetAllStudents')
                .then(response => response.json())
                .then(students => {
                    dbStudents = students;
                    
                    // Set up local storage representation of student sessions and rewards
                    dbStudents.forEach(s => {
                        if (!localStorage.getItem(`sess_${s.idNumber}`)) {
                            localStorage.setItem(`sess_${s.idNumber}`, '30'); // Default 30 sessions remaining
                        }
                        if (!localStorage.getItem(`pts_${s.idNumber}`)) {
                            localStorage.setItem(`pts_${s.idNumber}`, Math.floor(Math.random() * 800) + 100); // Random initial points
                        }
                    });

                    // Update UI components
                    renderStudentDatabaseTable(dbStudents);
                    updateDashboardStatistics();
                    renderLeaderboard();
                    populateStudentDropdowns();
                })
                .catch(error => {
                    console.error('Error fetching database students:', error);
                    // Generate mock DB if endpoint fails (isolated running support)
                    dbStudents = [
                        { idNumber: "22-0491", firstName: "Jameson", lastName: "Carter", email: "j.carter@ccs.edu", course: "BSCS", courseLevel: "3", address: "Mandaue City, Cebu" },
                        { idNumber: "23-0182", firstName: "Maria", lastName: "Santos", email: "m.santos@ccs.edu", course: "BSIT", courseLevel: "2", address: "Cebu City, Cebu" },
                        { idNumber: "21-0824", firstName: "Liam", lastName: "Henderson", email: "l.henderson@ccs.edu", course: "BSCS", courseLevel: "4", address: "Lapu-Lapu City, Cebu" },
                        { idNumber: "24-0012", firstName: "Angela", lastName: "Gomez", email: "a.gomez@ccs.edu", course: "BSIS", courseLevel: "1", address: "Talamban, Cebu" }
                    ];
                    dbStudents.forEach(s => {
                        if (!localStorage.getItem(`sess_${s.idNumber}`)) {
                            localStorage.setItem(`sess_${s.idNumber}`, '24');
                        }
                        if (!localStorage.getItem(`pts_${s.idNumber}`)) {
                            localStorage.setItem(`pts_${s.idNumber}`, '640');
                        }
                    });
                    renderStudentDatabaseTable(dbStudents);
                    updateDashboardStatistics();
                    renderLeaderboard();
                    populateStudentDropdowns();
                });
        }

        // DOMContentLoaded Setup
        document.addEventListener('DOMContentLoaded', function () {
            initializeDataState();
            fetchStudentsFromDatabase();

            // Wire sidebar click events
            document.querySelectorAll('.sidebar-menu-item').forEach(item => {
                item.addEventListener('click', function (e) {
                    e.preventDefault();
                    const targetTabId = this.getAttribute('data-tab');
                    switchTab(targetTabId);
                });
            });

            // Refresh ongoing sit-ins count at boot
            renderOngoingSitInsTable();
            renderSitInHistoryTable();
            renderReservationsTable();
            renderAnnouncements();
            renderFeedback();
            renderRecentRewardsLog();
        });

        // Tab Switcher with Title sync (smooth Single Page App feel)
        function switchTab(tabId) {
            // Remove active classes
            document.querySelectorAll('.sidebar-menu-item').forEach(i => i.classList.remove('active'));
            document.querySelectorAll('.tab-pane').forEach(t => t.classList.remove('active'));

            // Add active class to active sidebar item
            const activeSidebarLink = document.querySelector(`.sidebar-menu-item[data-tab="${tabId}"]`);
            if (activeSidebarLink) activeSidebarLink.classList.add('active');

            // Show target panel
            const targetPane = document.getElementById(tabId);
            if (targetPane) targetPane.classList.add('active');

            // Sync page Title in Top Navbar
            const titleMap = {
                'tab-dashboard': 'Admin Dashboard Analytics',
                'tab-students': 'Registered Student Information Directory',
                'tab-sitin': 'Manage Sit-In & PC Sessions',
                'tab-reservations': 'Laboratory Room Booking Reservations',
                'tab-announcements': 'Publish Bulletins & Campus Announcements',
                'tab-rewards': 'Student Loyalty Points & Gamified Rewards',
                'tab-feedback': 'Student Feedback Surveys & Reviews',
                'tab-reports': 'Generate Laboratory Compliance Reports'
            };
            document.getElementById('page-navbar-title').textContent = titleMap[tabId] || 'CCS System Management';

            // Scroll main container to top
            document.querySelector('.main-content').scrollTop = 0;
        }

        // Render Student Database Grid (with points/sessions fetched from local state)
        function renderStudentDatabaseTable(students) {
            const tbody = document.getElementById('students-database-tbody');
            tbody.innerHTML = '';

            if (students.length === 0) {
                tbody.innerHTML = `<tr><td colspan="8" style="text-align: center; color: var(--text-muted); padding: 2rem;">No students found in registered database.</td></tr>`;
                return;
            }

            students.forEach(student => {
                const sessions = localStorage.getItem(`sess_${student.idNumber}`) || '30';
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td><strong>${student.idNumber}</strong></td>
                    <td>${student.lastName}, ${student.firstName}</td>
                    <td>${student.email || 'N/A'}</td>
                    <td><span class="stat-badge" style="background: rgba(15, 61, 145, 0.1); color: var(--primary-blue); font-size: 0.65rem;">${student.course || 'N/A'}</span></td>
                    <td>${student.courseLevel || 'N/A'} Year</td>
                    <td>${student.address || 'N/A'}</td>
                    <td>
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                            <strong>${sessions} / 30</strong>
                            <div class="progress-bar" style="width: 60px; height: 6px; margin: 0;"><div class="progress-fill" style="width: ${(sessions / 30) * 100}%; background: var(--info-blue);"></div></div>
                        </div>
                    </td>
                    <td>
                        <button class="btn-action-sm primary" onclick="viewStudentProfile('${student.idNumber}')">🔍 View</button>
                        <button class="btn-action-sm danger" onclick="deleteStudentDatabase('${student.idNumber}')">🗑️ Delete</button>
                    </td>
                `;
                tbody.appendChild(row);
            });
        }

        // Dashboard statistics updates
        function updateDashboardStatistics() {
            document.getElementById('stats-total-students').textContent = dbStudents.length;
            document.getElementById('stats-active-sitins').textContent = ongoingSitIns.length;
            
            // Occupancy rate calculation (assume 160 total PCs in the department across 4 labs)
            const occupancyRate = Math.min(100, Math.round((ongoingSitIns.length / 160) * 100));
            document.getElementById('stats-occupancy-bar').style.width = `${occupancyRate}%`;
            document.getElementById('stats-occupancy-text').textContent = `${occupancyRate}% Occupied`;

            // Active sit ins list on home panel preview
            const previewTbody = document.getElementById('live-monitor-preview-tbody');
            previewTbody.innerHTML = '';
            if (ongoingSitIns.length === 0) {
                previewTbody.innerHTML = `<tr><td colspan="6" style="text-align: center; color: var(--text-muted); padding: 1.5rem;">No active sit-in sessions right now.</td></tr>`;
            } else {
                ongoingSitIns.slice(0, 3).forEach(s => {
                    const tr = document.createElement('tr');
                    tr.innerHTML = `
                        <td><strong>${s.studentId}</strong></td>
                        <td>${s.studentName}</td>
                        <td>Lab Room ${s.labRoom}</td>
                        <td>PC #${s.pcNumber}</td>
                        <td>${s.checkInTime}</td>
                        <td><span style="font-size: 0.75rem; color: var(--text-muted);">${s.purpose}</span></td>
                    `;
                    previewTbody.appendChild(tr);
                });
            }

            // Reservations count sync
            document.getElementById('stats-pending-reservations').textContent = reservations.filter(r => r.status === 'Pending').length;
            document.getElementById('sidebar-reservations-badge').textContent = reservations.filter(r => r.status === 'Pending').length;
        }

        // Leaderboard generator (Gold / Silver / Bronze badges gamification)
        function renderLeaderboard() {
            // Sort students based on rewards points stored in localStorage
            const studentRanks = dbStudents.map(s => {
                return {
                    idNumber: s.idNumber,
                    name: `${s.firstName} ${s.lastName}`,
                    course: s.course,
                    year: s.courseLevel,
                    points: parseInt(localStorage.getItem(`pts_${s.idNumber}`)) || 0,
                    hours: Math.round((parseInt(localStorage.getItem(`pts_${s.idNumber}`)) || 0) / 45) // Estimate hours
                };
            }).sort((a, b) => b.points - a.points);

            // Populate Main Rewards tab leaderboard
            const rewardsTbody = document.getElementById('rewards-leaderboard-tbody');
            rewardsTbody.innerHTML = '';
            
            studentRanks.forEach((student, index) => {
                const rankBadge = index === 0 ? "🥇 1st" : index === 1 ? "🥈 2nd" : index === 2 ? "🥉 3rd" : `${index + 1}th`;
                const tier = student.points > 1000 ? "🏆 Gold" : student.points > 500 ? "🥈 Silver" : "🥉 Bronze";
                const tierColor = student.points > 1000 ? "var(--accent-yellow)" : student.points > 500 ? "var(--text-muted)" : "brown";

                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td><strong>${rankBadge}</strong></td>
                    <td>${student.idNumber}</td>
                    <td>${student.name}</td>
                    <td>${student.course} - ${student.year} Year</td>
                    <td><strong style="color: var(--primary-blue); font-size: 0.95rem;">${student.points.toLocaleString()} ⭐</strong></td>
                    <td>${student.hours} Hours Checked</td>
                    <td><span class="stat-badge" style="background: ${tierColor}; color: white;">${tier} Tier</span></td>
                    <td><button class="btn-action-sm success" onclick="openAwardPointsModal('${student.idNumber}')">⭐ Award Points</button></td>
                `;
                rewardsTbody.appendChild(tr);
            });

            // Populate Mini Home dashboard leaderboard
            const miniList = document.getElementById('mini-leaderboard-list');
            miniList.innerHTML = '';
            studentRanks.slice(0, 3).forEach((student, index) => {
                const medal = index === 0 ? "🥇" : index === 1 ? "🥈" : "🥉";
                const div = document.createElement('div');
                div.style = "display: flex; align-items: center; justify-content: space-between; padding: 0.75rem; background: var(--light-bg); border-radius: 10px;";
                div.innerHTML = `
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <span style="font-size: 1.2rem;">${medal}</span>
                        <div>
                            <h4 style="font-size: 0.8rem; font-weight: 700; color: var(--text-dark);">${student.name}</h4>
                            <p style="font-size: 0.65rem; color: var(--text-muted);">${student.course} - Year ${student.year}</p>
                        </div>
                    </div>
                    <span style="font-weight: 700; color: var(--primary-blue); font-size: 0.85rem;">${student.points} ⭐</span>
                `;
                miniList.appendChild(div);
            });
        }

        // Dropdowns setup
        function populateStudentDropdowns() {
            const awardSelect = document.getElementById('award-id');
            const quickSelect = document.getElementById('quick-id');
            awardSelect.innerHTML = '<option value="">-- Choose Student --</option>';
            quickSelect.innerHTML = '<option value="">-- Select Student to Check-In --</option>';

            dbStudents.forEach(s => {
                const optText = `${s.idNumber} - ${s.lastName}, ${s.firstName} (${s.course})`;
                
                const opt1 = document.createElement('option');
                opt1.value = s.idNumber;
                opt1.textContent = optText;
                awardSelect.appendChild(opt1);

                const opt2 = document.createElement('option');
                opt2.value = s.idNumber;
                opt2.textContent = optText;
                quickSelect.appendChild(opt2);
            });
