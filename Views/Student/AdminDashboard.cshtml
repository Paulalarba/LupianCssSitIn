        // Search directory client-side
        function searchStudents() {
            const query = document.getElementById('students-search-input').value.toLowerCase().trim();
            if (!query) {
                renderStudentDatabaseTable(dbStudents);
                return;
            }

            const matches = dbStudents.filter(s => 
                s.idNumber.toLowerCase().includes(query) || 
                s.firstName.toLowerCase().includes(query) || 
                s.lastName.toLowerCase().includes(query)
            );
            renderStudentDatabaseTable(matches);
        }

        function clearStudentSearch() {
            document.getElementById('students-search-input').value = '';
            document.getElementById('students-filter-course').value = '';
            document.getElementById('students-filter-year').value = '';
            renderStudentDatabaseTable(dbStudents);
        }

        // Filtering tables
        function filterStudentsTable() {
            const courseFilter = document.getElementById('students-filter-course').value;
            const yearFilter = document.getElementById('students-filter-year').value;

            let filtered = dbStudents;
            if (courseFilter) {
                filtered = filtered.filter(s => s.course === courseFilter);
            }
            if (yearFilter) {
                filtered = filtered.filter(s => s.courseLevel === yearFilter);
            }
            renderStudentDatabaseTable(filtered);
        }

        // Verification check-in autofill helper
        function checkInAutofill() {
            const idInput = document.getElementById('checkin-id').value.trim();
            if (!idInput) {
                alert('Please enter a Student ID number first.');
                return;
            }

            const student = dbStudents.find(s => s.idNumber === idInput);
            if (student) {
                document.getElementById('checkin-name').value = `${student.firstName} ${student.lastName} (${student.course})`;
            } else {
                alert(`Student ID ${idInput} not found. Searching real DB...`);
                fetch(`/Student/GetStudentById?id=${encodeURIComponent(idInput)}`)
                    .then(r => r.json())
                    .then(data => {
                        if (data && data.idNumber) {
                            document.getElementById('checkin-name').value = `${data.firstName} ${data.lastName} (${data.course})`;
                            // Add student dynamically
                            dbStudents.push(data);
                            populateStudentDropdowns();
                        } else {
                            alert('Student ID not found in database registry. Please register them first.');
                            document.getElementById('checkin-name').value = '';
                        }
                    })
                    .catch(err => {
                        console.error(err);
                        alert('Database offline/locked. Registration required.');
                    });
            }
        }

        // Handle checkin submit
        function handleCheckInSubmit(e) {
            e.preventDefault();
            const idInput = document.getElementById('checkin-id').value.trim();
            const nameInput = document.getElementById('checkin-name').value;
            const labInput = document.getElementById('checkin-lab').value;
            const pcInput = document.getElementById('checkin-pc').value;
            const purposeInput = document.getElementById('checkin-purpose').value;

            if (!nameInput) {
                alert('Please verify the Student ID first by clicking the Verify button.');
                return;
            }

            // Check if already sitting in
            if (ongoingSitIns.find(s => s.studentId === idInput)) {
                alert('This student is already checked in to an active session.');
                return;
            }

            // Validate PC room occupancy
            if (ongoingSitIns.find(s => s.labRoom === labInput && s.pcNumber === pcInput)) {
                alert(`PC #${pcInput} in Lab Room ${labInput} is already occupied by another student! Choose another unit.`);
                return;
            }

            // Deduct sessions check
            const sessionsRem = parseInt(localStorage.getItem(`sess_${idInput}`)) || 30;
            if (sessionsRem <= 0) {
                alert('Inadequate sessions! This student has zero remaining lab slots left.');
                return;
            }

            // Add ongoing session
            const newSession = {
                studentId: idInput,
                studentName: nameInput.split(' (')[0],
                labRoom: labInput,
                pcNumber: pcInput,
                checkInTime: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
                purpose: purposeInput
            };

            ongoingSitIns.push(newSession);
            localStorage.setItem('admin_ongoing_sitins', JSON.stringify(ongoingSitIns));

            renderOngoingSitInsTable();
            updateDashboardStatistics();
            
            // Clear checkin form
            document.getElementById('checkin-form').reset();
            document.getElementById('checkin-name').value = '';
            
            alert(`Sit-in session created successfully for student PC #${pcInput} in Lab Room ${labInput}.`);
        }

        // Quick check-in submission handler
        function handleQuickCheckInSubmit(e) {
            e.preventDefault();
            const studentId = document.getElementById('quick-id').value;
            const lab = document.getElementById('quick-lab').value;
            const pc = document.getElementById('quick-pc').value;
            const purpose = document.getElementById('quick-purpose').value;

            if (!studentId) {
                alert('Please select a student.');
                return;
            }

            const student = dbStudents.find(s => s.idNumber === studentId);
            if (!student) return;

            // Check if already sitting in
            if (ongoingSitIns.find(s => s.studentId === studentId)) {
                alert('This student is already checked in.');
                return;
            }

            // PC check
            if (ongoingSitIns.find(s => s.labRoom === lab && s.pcNumber === pc)) {
                alert(`PC #${pc} in Room ${lab} is currently occupied.`);
                return;
            }

            const sessionsRem = parseInt(localStorage.getItem(`sess_${studentId}`)) || 30;
            if (sessionsRem <= 0) {
                alert('Inadequate sessions remain.');
                return;
            }

            const newSession = {
                studentId: studentId,
                studentName: `${student.firstName} ${student.lastName}`,
                labRoom: lab,
                pcNumber: pc,
                checkInTime: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
                purpose: purpose
            };

            ongoingSitIns.push(newSession);
            localStorage.setItem('admin_ongoing_sitins', JSON.stringify(ongoingSitIns));

            renderOngoingSitInsTable();
            updateDashboardStatistics();
            closeModal('quick-checkin-modal');

            alert(`Checked-In successfully.`);
