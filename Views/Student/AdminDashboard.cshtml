                    </div>
                    <span style="font-weight: 700; color: var(--success-green);">+${r.amount} pts</span>
                `;
                container.appendChild(div);
            });
        }

        // ================== GENERATE REPORTS (CSV, Docs, PDF) ==================
        function generateReport() {
            const type = document.getElementById('report-data-type').value;
            const scope = document.getElementById('report-date-range').value;
            const format = document.getElementById('report-format').value;

            let reportData = [];
            let columns = [];
            let title = '';

            if (type === 'students') {
                title = 'CCS Registered Students Directory Report';
                columns = ['Student ID', 'Last Name', 'First Name', 'Email', 'Course', 'Year Level', 'Remaining Sessions', 'Reward Points'];
                reportData = dbStudents.map(s => {
                    return [
                        s.idNumber,
                        s.lastName,
                        s.firstName,
                        s.email,
                        s.course,
                        s.courseLevel,
                        localStorage.getItem(`sess_${s.idNumber}`) || '30',
                        localStorage.getItem(`pts_${s.idNumber}`) || '100'
                    ];
                });
            } else if (type === 'current-sitins') {
                title = 'CCS Active Lab Sit-In Audit Report';
                columns = ['Student ID', 'Student Name', 'Lab Room', 'PC Number', 'Check-In Time', 'Purpose'];
                reportData = ongoingSitIns.map(s => [s.studentId, s.studentName, s.labRoom, s.pcNumber, s.checkInTime, s.purpose]);
            } else if (type === 'sit-in-logs') {
                title = 'CCS Historical Lab Sit-In Log Report';
                columns = ['Student ID', 'Student Name', 'Lab Room', 'PC Number', 'Check-In DateTime', 'Check-Out DateTime', 'Purpose'];
                reportData = sitInHistory.map(h => [h.studentId, h.studentName, h.labRoom, h.pcNumber, h.checkInTime, h.checkOutTime, h.purpose]);
            } else if (type === 'reservations') {
                title = 'CCS Lab Slot Reservations Allocation Report';
                columns = ['Res ID', 'Student ID', 'Student Name', 'Lab Room', 'PC', 'Date', 'Time Slot', 'Status'];
                reportData = reservations.map(r => [r.id, r.studentId, r.studentName, r.labRoom, r.pcNumber, r.date, r.timeSlot, r.status]);
            } else if (type === 'feedback') {
                title = 'CCS Systems & Infrastructure Service Feedback Report';
                columns = ['Date', 'Student Name', 'Category', 'Subject', 'Message', 'Rating', 'Status'];
                reportData = feedbackLogs.map(f => [f.date, f.studentName, f.category, f.subject, f.message, f.rating + " Stars", f.status]);
            }

            const filename = `${type}_report_${new Date().toISOString().split('T')[0]}`;

            // Trigger corresponding exporter
            if (format === 'csv') {
                exportCSV(columns, reportData, filename);
            } else if (format === 'doc') {
                exportDOC(title, columns, reportData, filename);
            } else if (format === 'pdf') {
                exportPDF(title, columns, reportData);
            }
        }

        // Native CSV download
        function exportCSV(headers, rows, filename) {
            let csvContent = "data:text/csv;charset=utf-8,";
            
            // Append header line
            csvContent += headers.join(",") + "\r\n";
            
            // Append data rows
            rows.forEach(row => {
                const escapedRow = row.map(val => {
                    let str = String(val).replace(/"/g, '""'); // escape quotes
                    if (str.includes(",") || str.includes("\n")) {
                        str = `"${str}"`; // wrap in quotes if commas exist
                    }
                    return str;
                });
                csvContent += escapedRow.join(",") + "\r\n";
            });

            const encodedUri = encodeURI(csvContent);
            const link = document.createElement("a");
            link.setAttribute("href", encodedUri);
            link.setAttribute("download", `${filename}.csv`);
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }

        // Native Microsoft Word (.doc) formatted download with gorgeous inline styling
        function exportDOC(title, headers, rows, filename) {
            let htmlTable = `
                <h1 style="color:oklch(38% 0.12 258); font-family: Arial, sans-serif; text-align:center; margin-bottom: 2rem;">${title}</h1>
                <p style="font-family: Arial; font-size: 0.95rem; color:oklch(48% 0.032 250);">Date Generated: ${new Date().toLocaleString()}</p>
                <p style="font-family: Arial; font-size: 0.95rem; color:oklch(48% 0.032 250);">Generated By: System Administrator (CCS Monitoring System)</p>
                <br/>
                <table style="width:100%; border-collapse:collapse; font-family: Arial; font-size:0.85rem;">
                    <thead>
                        <tr style="background-color:oklch(38% 0.12 258); color:white;">
                            ${headers.map(h => `<th style="padding:10px; border:1px solid oklch(89% 0.018 250); text-align:left;">${h}</th>`).join('')}
                        </tr>
                    </thead>
                    <tbody>
                        ${rows.map(row => `
                            <tr>
                                ${row.map(val => `<td style="padding:10px; border:1px solid oklch(89% 0.018 250);">${val}</td>`).join('')}
                            </tr>
                        `).join('')}
                    </tbody>
                </table>
            `;

            const header = "<html xmlns:o='urn:schemas-microsoft-com:office:office' "+
                  "xmlns:w='urn:schemas-microsoft-com:office:word' "+
                  "xmlns='http://www.w3.org/TR/REC-html40'>"+
                  "<head><title>CCS Compliance Report</title><style>body {font-family: Arial, sans-serif;}</style></head><body>";
            const footer = "</body></html>";
            const sourceHTML = header + htmlTable + footer;
            
            const source = 'data:application/vnd.ms-word;charset=utf-8,' + encodeURIComponent(sourceHTML);
            const fileDownload = document.createElement("a");
            document.body.appendChild(fileDownload);
            fileDownload.href = source;
            fileDownload.download = `${filename}.doc`;
            fileDownload.click();
            document.body.removeChild(fileDownload);
        }

        // Native PDF Exporter via print window overlay layout
        function exportPDF(title, headers, rows) {
            const printArea = document.getElementById('print-report-container');
            printArea.style.display = 'block';
            printArea.innerHTML = `
                <div style="display:flex; justify-content:space-between; align-items:center; border-bottom: 3px solid oklch(38% 0.12 258); padding-bottom:1.5rem; margin-bottom:2rem;">
                    <div>
                        <h1 style="color:oklch(38% 0.12 258); font-size: 1.8rem; font-weight:800; margin:0;">COLLEGE OF COMPUTER STUDIES</h1>
                        <p style="font-size:0.9rem; color:oklch(48% 0.032 250); margin: 0.25rem 0 0 0;">CCS Academic & Lab Monitoring System Report</p>
                    </div>
                    <div style="text-align:right;">
                        <h2 style="font-size:1.1rem; color:oklch(24% 0.035 250); margin:0;">COMPLIANCE AUDIT DOCUMENT</h2>
                        <p style="font-size:0.75rem; color:oklch(48% 0.032 250); margin:0.25rem 0 0 0;">CONFIDENTIAL</p>
                    </div>
                </div>

                <h2 style="color:oklch(29% 0.11 258); font-size:1.3rem; margin-bottom: 1.5rem;">${title}</h2>
                <div style="display:flex; justify-content:space-between; font-size: 0.8rem; color:oklch(48% 0.032 250); margin-bottom:2rem;">
                    <span>Date Generated: ${new Date().toLocaleString()}</span>
                    <span>Issued By: System Administrator</span>
                </div>

                <table style="width:100%; border-collapse:collapse; font-size:0.8rem;">
                    <thead>
                        <tr style="background-color:oklch(38% 0.12 258); color:white;">
                            ${headers.map(h => `<th style="padding:12px; border:1px solid oklch(89% 0.018 250); text-align:left;">${h}</th>`).join('')}
                        </tr>
                    </thead>
                    <tbody>
                        ${rows.map(row => `
                            <tr style="page-break-inside:avoid;">
                                ${row.map(val => `<td style="padding:10px; border:1px solid oklch(89% 0.018 250);">${val}</td>`).join('')}
                            </tr>
                        `).join('')}
                    </tbody>
                </table>

                <div style="margin-top:4rem; page-break-inside:avoid; display:flex; justify-content:flex-end;">
                    <div style="text-align:center; width:220px; border-top: 1px solid oklch(48% 0.032 250); padding-top:0.5rem;">
                        <strong style="font-size:0.85rem; color:oklch(24% 0.035 250);">System Administrator</strong>
                        <p style="font-size:0.75rem; color:oklch(48% 0.032 250); margin:0;">CCS Dean's Office Authorized Signature</p>
                    </div>
                </div>
            `;

            window.print();
            printArea.style.display = 'none';
            printArea.innerHTML = '';
        }

        // ================== GENERAL MODALS ==================
        function openModal(id) {
            const m = document.getElementById(id);
            if (m) m.classList.add('active');
        }

        function closeModal(id) {
            const m = document.getElementById(id);
            if (m) m.classList.remove('active');
        }

        // Bind outside clicks and escape key
        document.querySelectorAll('.modal-overlay').forEach(o => {
            o.addEventListener('click', function(e) {
                if (e.target === this) closeModal(this.id);
            });
        });
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                document.querySelectorAll('.modal-overlay.active').forEach(o => closeModal(o.id));
            }
        });
    </script>
</body>
</html>