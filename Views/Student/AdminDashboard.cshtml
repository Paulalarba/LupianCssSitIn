        function handleAnnouncementSubmit(e) {
            e.preventDefault();
            const title = document.getElementById('announcement-title').value;
            const tag = document.getElementById('announcement-tag').value;
            const scope = document.getElementById('announcement-scope').value;
            const desc = document.getElementById('announcement-desc').value;

            const newAnn = {
                id: announcements.length > 0 ? Math.max(...announcements.map(a => a.id)) + 1 : 1,
                title: title,
                tag: tag,
                scope: scope,
                desc: desc,
                date: "Just Now"
            };

            announcements.unshift(newAnn); // Add to top
            localStorage.setItem('admin_announcements', JSON.stringify(announcements));
            
            renderAnnouncements();
            e.target.reset();
            alert('New Announcement broadcast successfully!');
