@model CCSMonitoringSystem.Models.Student
@{
    Layout = null;
    ViewData["Title"] = "Create Student Account";
}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>@ViewData["Title"] - UC CCS Portal</title>
  <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
  <style>
    :root {
      color-scheme: dark;
      --uc-blue-900: oklch(23% 0.095 258);
      --uc-blue-800: oklch(30% 0.11 258);
      --uc-blue-650: oklch(42% 0.13 258);
      --uc-gold-500: oklch(79% 0.14 82);
      --uc-gold-600: oklch(70% 0.14 76);
      --ink-950: oklch(18% 0.035 270);
      --ink-900: oklch(22% 0.035 270);
      --ink-820: oklch(28% 0.035 270);
      --ink-760: oklch(34% 0.034 270);
      --text-strong: oklch(97% 0.006 250);
      --text: oklch(88% 0.01 250);
      --text-muted: oklch(70% 0.014 250);
      --line: oklch(46% 0.04 270);
      --danger: oklch(72% 0.16 25);
      --success: oklch(76% 0.15 154);
      --shadow: 0 26px 70px rgba(4, 10, 29, 0.48);
      --radius: 8px;
      --focus: color-mix(in oklch, var(--uc-gold-500) 38%, transparent);
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      min-height: 100%;
      margin: 0;
    }

    body {
      font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
      color: var(--text);
      background:
        linear-gradient(90deg, rgba(4, 26, 70, 0.88), rgba(9, 56, 132, 0.72)),
        url("https://images.unsplash.com/photo-1607237138185-eedd9c632b0b?w=1800&auto=format&fit=crop&q=82");
      background-position: center;
      background-size: cover;
      background-attachment: fixed;
    }

    a {
      color: var(--uc-gold-500);
      font-weight: 700;
      text-decoration: none;
    }

    a:hover {
      color: oklch(86% 0.12 84);
      text-decoration: underline;
    }

    .register-shell {
      min-height: 100vh;
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(min(100%, 360px), 520px);
      gap: clamp(1.5rem, 4vw, 4rem);
      align-items: stretch;
      padding: clamp(1rem, 2.4vw, 2.5rem);
      position: relative;
    }

    .register-shell::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 18% 16%, rgba(255, 191, 54, 0.16), transparent 26rem),
        linear-gradient(180deg, rgba(0, 12, 38, 0.12), rgba(0, 18, 50, 0.44));
    }

    .intro-panel,
    .form-panel {
      position: relative;
      z-index: 1;
    }

    .intro-panel {
      min-height: calc(100svh - clamp(2rem, 4.8vw, 5rem));
      display: grid;
      grid-template-rows: auto 1fr auto;
      align-items: center;
      max-width: 760px;
      padding: clamp(0.5rem, 2vw, 2rem) 0;
    }

    .brand-mark {
      width: fit-content;
      display: inline-flex;
      align-items: center;
      gap: 0.8rem;
      padding: 0.65rem 0.85rem;
      border: 1px solid rgba(255, 191, 54, 0.32);
      border-radius: var(--radius);
      background: rgba(7, 36, 91, 0.66);
      box-shadow: 0 18px 42px rgba(0, 0, 0, 0.18);
    }

    .brand-logo {
      width: 42px;
      height: 42px;
      display: grid;
      place-items: center;
      border-radius: var(--radius);
      background: linear-gradient(145deg, var(--uc-gold-500), oklch(86% 0.11 88));
      color: var(--uc-blue-900);
      font-size: 0.66rem;
      font-weight: 900;
      line-height: 0.9;
      letter-spacing: 0;
      text-align: center;
    }

    .brand-text {
      display: grid;
      gap: 0.1rem;
      font-size: 0.84rem;
      font-weight: 800;
      color: var(--text-strong);
    }

    .brand-text span {
      color: var(--uc-gold-500);
      font-size: 0.65rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .intro-copy {
      max-width: 650px;
      align-self: center;
      justify-self: center;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding-bottom: 0;
    }

    .eyebrow {
      width: fit-content;
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      margin-bottom: 1rem;
      padding: 0.42rem 0.78rem;
      border: 1px solid rgba(255, 191, 54, 0.38);
      border-radius: 999px;
      color: var(--uc-gold-500);
      background: rgba(17, 33, 69, 0.62);
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .intro-copy h1 {
      max-width: 680px;
      margin: 0 0 1rem;
      color: var(--text-strong);
      font-size: 3.8rem;
      font-weight: 850;
      line-height: 1.02;
      letter-spacing: 0;
      text-shadow: 0 14px 34px rgba(2, 8, 24, 0.52);
    }

    .intro-copy h1 span {
      color: var(--uc-gold-500);
      display: block;
    }

    .intro-copy p {
      max-width: 56ch;
      margin: 0;
      color: var(--text);
      font-size: 1.04rem;
      line-height: 1.75;
      text-shadow: 0 8px 20px rgba(2, 8, 24, 0.36);
    }

    .intro-footer {
      color: oklch(82% 0.05 84);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .form-panel {
      align-self: start;
      width: 100%;
      max-width: 520px;
      justify-self: end;
      padding-bottom: clamp(1rem, 3vh, 2rem);
    }

    .form-card {
      width: 100%;
      border: 1px solid rgba(255, 191, 54, 0.18);
      border-radius: 12px;
      background: color-mix(in oklch, var(--ink-950) 94%, transparent);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .form-header,
    .form-body,
    .form-footer {
      padding-inline: clamp(1.15rem, 3vw, 2rem);
    }

    .form-header {
      padding-top: clamp(1.25rem, 3vw, 2rem);
      padding-bottom: 1.1rem;
      border-bottom: 1px solid rgba(255, 191, 54, 0.14);
      background: linear-gradient(180deg, rgba(255, 191, 54, 0.08), transparent);
    }

    .page-badge {
      width: fit-content;
      margin-bottom: 0.85rem;
      padding: 0.36rem 0.74rem;
      border: 1px solid rgba(255, 191, 54, 0.38);
      border-radius: 999px;
      color: var(--uc-gold-500);
      background: rgba(255, 191, 54, 0.08);
      font-size: 0.68rem;
      font-weight: 850;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .form-title {
      margin: 0 0 0.45rem;
      color: var(--text-strong);
      font-size: 2rem;
      font-weight: 850;
      line-height: 1.08;
      letter-spacing: 0;
    }

    .form-sub {
      max-width: 46ch;
      margin: 0;
      color: var(--text-muted);
      font-size: 0.94rem;
      line-height: 1.6;
    }

    .form-body {
      padding-top: 1.35rem;
      padding-bottom: 1.25rem;
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.9rem 0.85rem;
    }

    .field-group {
      min-width: 0;
    }

    .field-group.full {
      grid-column: 1 / -1;
    }

    .field-label {
      display: flex;
      align-items: baseline;
      gap: 0.35rem;
      margin: 0 0 0.42rem;
      color: var(--text);
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .optional-badge {
      color: var(--text-muted);
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0;
      text-transform: none;
    }

    .input-wrap input,
    .input-wrap select {
      width: 100%;
      min-height: 46px;
      padding: 0.78rem 0.9rem;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      outline: none;
      background: var(--ink-820);
      color: var(--text-strong);
      font: inherit;
      font-size: 0.94rem;
      transition: border-color 180ms ease, box-shadow 180ms ease, background-color 180ms ease;
    }

    .input-wrap select {
      cursor: pointer;
    }

    .input-wrap input::placeholder {
      color: oklch(66% 0.012 250);
    }

    .input-wrap input:hover,
    .input-wrap select:hover {
      border-color: oklch(55% 0.055 84);
      background: var(--ink-760);
    }

    .input-wrap input:focus,
    .input-wrap select:focus {
      border-color: var(--uc-gold-500);
      box-shadow: 0 0 0 4px var(--focus);
      background: var(--ink-760);
    }

    .val-error {
      display: block;
      min-height: 1rem;
      margin-top: 0.28rem;
      color: var(--danger);
      font-size: 0.75rem;
      font-weight: 650;
      line-height: 1.35;
    }

    .validation-summary {
      margin-bottom: 1rem;
      padding: 0.9rem 1rem;
      border: 1px solid color-mix(in oklch, var(--danger) 58%, transparent);
      border-radius: var(--radius);
      background: color-mix(in oklch, var(--danger) 14%, transparent);
      color: oklch(84% 0.10 25);
      font-size: 0.86rem;
    }

    .validation-summary strong {
      display: block;
      margin-bottom: 0.45rem;
      color: oklch(90% 0.08 25);
    }

    .validation-summary ul {
      margin: 0;
      padding-left: 1.1rem;
    }

    .file-upload-label {
      display: grid;
      gap: 0.2rem;
      min-height: 84px;
      padding: 0.9rem;
      border: 1px dashed color-mix(in oklch, var(--uc-gold-500) 45%, var(--line));
      border-radius: var(--radius);
      background: color-mix(in oklch, var(--ink-820) 86%, var(--uc-gold-500) 4%);
      cursor: pointer;
      text-align: center;
      transition: border-color 180ms ease, background-color 180ms ease, box-shadow 180ms ease;
    }

    .file-upload-label:hover,
    .file-upload-label.is-dragging {
      border-color: var(--uc-gold-500);
      background: var(--ink-760);
      box-shadow: 0 0 0 4px var(--focus);
    }

    .file-upload-label input {
      display: none;
    }

    .file-upload-icon {
      color: var(--uc-gold-500);
      font-size: 1rem;
      font-weight: 900;
    }

    .file-upload-text {
      margin: 0;
      color: var(--text);
      font-size: 0.88rem;
      font-weight: 700;
    }

    .file-upload-hint,
    .file-name {
      margin: 0;
      color: var(--text-muted);
      font-size: 0.76rem;
    }

    .file-name {
      color: var(--uc-gold-500);
      font-weight: 800;
      word-break: break-word;
    }

    .btn-register {
      width: 100%;
      min-height: 48px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.55rem;
      margin-top: 0.2rem;
      border: 0;
      border-radius: var(--radius);
      background: linear-gradient(180deg, var(--uc-gold-500), var(--uc-gold-600));
      color: var(--uc-blue-900);
      font-size: 0.92rem;
      font-weight: 900;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      box-shadow: 0 14px 28px rgba(255, 191, 54, 0.18);
      transition: transform 180ms ease, box-shadow 180ms ease, filter 180ms ease;
    }

    .btn-register:hover {
      transform: translateY(-1px);
      filter: brightness(1.04);
      box-shadow: 0 18px 34px rgba(255, 191, 54, 0.24);
    }

    .btn-register:focus-visible {
      outline: none;
      box-shadow: 0 0 0 4px var(--focus), 0 18px 34px rgba(255, 191, 54, 0.22);
    }

    .form-footer {
      padding-top: 1rem;
      padding-bottom: clamp(1.15rem, 3vw, 1.7rem);
      border-top: 1px solid rgba(255, 191, 54, 0.14);
      text-align: center;
    }

    .login-prompt {
      margin: 0 0 0.85rem;
      color: var(--text-muted);
      font-size: 0.92rem;
    }

    .page-footer-links {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.8rem 1rem;
      font-size: 0.75rem;
    }

    .page-footer-links a {
      color: var(--text-muted);
      font-weight: 700;
    }

    @@media (max-width: 1180px) {
      .register-shell {
        grid-template-columns: minmax(0, 0.86fr) minmax(360px, 500px);
      }

      .intro-copy h1 {
        font-size: 3.05rem;
      }
    }

    @@media (max-width: 980px) {
      body {
        background-position: 35% center;
      }

      .register-shell {
        grid-template-columns: 1fr;
        gap: 1.25rem;
        align-items: start;
      }

      .intro-panel {
        min-height: auto;
        max-width: 760px;
        grid-template-rows: auto auto;
        gap: 1.6rem;
        margin-inline: auto;
        padding: 0;
      }

      .intro-copy {
        align-self: auto;
        padding-bottom: 0;
      }

      .intro-copy h1 {
        font-size: 2.35rem;
      }

      .intro-copy p {
        font-size: 0.98rem;
      }

      .intro-footer {
        display: none;
      }

      .form-panel {
        max-width: 760px;
        justify-self: center;
      }
    }

    @@media (max-width: 620px) {
      .register-shell {
        padding: 0.8rem;
      }

      .brand-mark {
        padding: 0.55rem 0.65rem;
      }

      .brand-logo {
        width: 38px;
        height: 38px;
      }

      .intro-copy h1 {
        font-size: 2rem;
      }

      .intro-copy p {
        font-size: 0.92rem;
        line-height: 1.6;
      }

      .form-grid {
        grid-template-columns: 1fr;
      }

      .form-title {
        font-size: 1.65rem;
      }

      .form-card {
        border-radius: 10px;
      }
    }

    @@media (max-height: 760px) and (min-width: 981px) {
      .register-shell {
        align-items: start;
      }

      .intro-panel {
        min-height: auto;
        position: sticky;
        top: 1rem;
      }

      .intro-copy h1 {
        font-size: 2.85rem;
      }

      .intro-copy p {
        font-size: 0.95rem;
        line-height: 1.55;
      }

      .form-header {
        padding-top: 1.35rem;
      }

      .form-body {
        padding-top: 1rem;
      }

      .form-grid {
        gap: 0.68rem 0.72rem;
      }

      .input-wrap input,
      .input-wrap select {
        min-height: 42px;
        padding-block: 0.62rem;
      }
    }
  </style>
</head>
<body>
  <main class="register-shell">
    <section class="intro-panel" aria-label="UC CCS Portal introduction">
      <div class="brand-mark">
        <div class="brand-logo">UC<br />CCS</div>
        <div class="brand-text">
          UC CCS
          <span>Student Portal</span>
        </div>
      </div>

      <div class="intro-copy">
        <div class="eyebrow">New student registration</div>
        <h1>Join the CCS <span>Community</span></h1>
        <p>Create one student account for CCS announcements, course records, lab reservations, sit-in monitoring, rewards, and profile updates.</p>
      </div>

      <div class="intro-footer">University of Cebu, College of Computer Studies</div>
    </section>

    <section class="form-panel" aria-label="Create student account form">
      <div class="form-card">
        <header class="form-header">
          <div class="page-badge">Create account</div>
          <h2 class="form-title">Student registration</h2>
          <p class="form-sub">Use your student details. Required fields are checked before your account is created.</p>
        </header>

        <div class="form-body">
          @if (ViewData.ModelState.IsValid == false)
          {
            <div class="validation-summary">
              <strong>Please correct the following:</strong>
              <ul>
                @foreach (var modelState in ViewData.ModelState.Values)
                {
                  @foreach (var error in modelState.Errors)
                  {
                    <li>@error.ErrorMessage</li>
                  }
                }
              </ul>
            </div>
          }

          <form asp-action="Register" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="form-grid">
              <div class="field-group">
                <label asp-for="FirstName" class="field-label">First name</label>
                <div class="input-wrap">
                  <input asp-for="FirstName" autocomplete="given-name" placeholder="Juan" />
                </div>
                <span asp-validation-for="FirstName" class="val-error"></span>
              </div>

              <div class="field-group">
                <label asp-for="MiddleName" class="field-label">Middle name <span class="optional-badge">optional</span></label>
                <div class="input-wrap">
                  <input asp-for="MiddleName" autocomplete="additional-name" placeholder="Middle name" />
                </div>
              </div>

              <div class="field-group">
                <label asp-for="LastName" class="field-label">Last name</label>
                <div class="input-wrap">
                  <input asp-for="LastName" autocomplete="family-name" placeholder="Dela Cruz" />
                </div>
                <span asp-validation-for="LastName" class="val-error"></span>
              </div>

              <div class="field-group">
                <label asp-for="IdNumber" class="field-label">ID number</label>
                <div class="input-wrap">
                  <input asp-for="IdNumber" inputmode="text" placeholder="23-123-456" />
                </div>
                <span asp-validation-for="IdNumber" class="val-error"></span>
              </div>

              <div class="field-group">
                <label asp-for="Course" class="field-label">Course</label>
                <div class="input-wrap">
                  <select asp-for="Course">
                    <option value="">Select course</option>
                    <option value="BSIT">BSIT</option>
                    <option value="BSCS">BSCS</option>
                    <option value="BSCE">BSCE</option>
                    <option value="BSIS">BSIS</option>
                  </select>
                </div>
                <span asp-validation-for="Course" class="val-error"></span>
              </div>

              <div class="field-group">
                <label asp-for="CourseLevel" class="field-label">Year level</label>
                <div class="input-wrap">
                  <select asp-for="CourseLevel">
                    <option value="">Select level</option>
                    <option value="1">1st Year</option>
                    <option value="2">2nd Year</option>
                    <option value="3">3rd Year</option>
                    <option value="4">4th Year</option>
                  </select>
                </div>
                <span asp-validation-for="CourseLevel" class="val-error"></span>
              </div>

              <div class="field-group full">
                <label asp-for="Email" class="field-label">Email address</label>
                <div class="input-wrap">
                  <input asp-for="Email" type="email" autocomplete="email" placeholder="yourname@uc.edu.ph" />
                </div>
                <span asp-validation-for="Email" class="val-error"></span>
              </div>

              <div class="field-group full">
                <label asp-for="Address" class="field-label">Address</label>
                <div class="input-wrap">
                  <input asp-for="Address" autocomplete="street-address" placeholder="Complete address" />
                </div>
                <span asp-validation-for="Address" class="val-error"></span>
              </div>

              <div class="field-group">
                <label asp-for="Password" class="field-label">Password</label>
                <div class="input-wrap">
                  <input asp-for="Password" type="password" autocomplete="new-password" placeholder="Minimum 6 characters" />
                </div>
                <span asp-validation-for="Password" class="val-error"></span>
              </div>

              <div class="field-group">
                <label asp-for="ConfirmPassword" class="field-label">Confirm password</label>
                <div class="input-wrap">
                  <input asp-for="ConfirmPassword" type="password" autocomplete="new-password" placeholder="Re-enter password" />
                </div>
                <span asp-validation-for="ConfirmPassword" class="val-error"></span>
              </div>

              <div class="field-group full">
                <label class="field-label" for="profilePictureFile">Profile picture <span class="optional-badge">optional</span></label>
                <label class="file-upload-label" for="profilePictureFile">
                  <span class="file-upload-icon" aria-hidden="true">Upload</span>
                  <p class="file-upload-text">Choose a photo or drag it here</p>
                  <p class="file-upload-hint">PNG, JPG, or GIF, up to 10MB</p>
                  <p class="file-name" id="fileName" aria-live="polite"></p>
                  <input type="file" id="profilePictureFile" name="profilePictureFile" accept="image/*" />
                </label>
              </div>

              <div class="field-group full">
                <button type="submit" class="btn-register">
                  <span aria-hidden="true">+</span>
                  <span>Create account</span>
                </button>
              </div>
            </div>
          </form>
        </div>

        <footer class="form-footer">
          <p class="login-prompt">Already have an account? <a href="/Student/Index">Sign in</a></p>
          <div class="page-footer-links">
            <a href="#">Help</a>
            <a href="/Home/Privacy">Privacy</a>
            <a href="#">Terms</a>
          </div>
        </footer>
      </div>
    </section>
  </main>

  <script src="~/lib/jquery/dist/jquery.min.js"></script>
  <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
  <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
  <script>
    const fileInput = document.getElementById("profilePictureFile");
    const fileName = document.getElementById("fileName");
    const fileLabel = document.querySelector(".file-upload-label");

    if (fileInput && fileName && fileLabel) {
      fileInput.addEventListener("change", function (event) {
        const file = event.target.files && event.target.files[0];
        fileName.textContent = file ? file.name : "";
      });

      ["dragenter", "dragover", "dragleave", "drop"].forEach(function (eventName) {
        fileLabel.addEventListener(eventName, function (event) {
          event.preventDefault();
          event.stopPropagation();
        });
      });

      ["dragenter", "dragover"].forEach(function (eventName) {
        fileLabel.addEventListener(eventName, function () {
          fileLabel.classList.add("is-dragging");
        });
      });

      ["dragleave", "drop"].forEach(function (eventName) {
        fileLabel.addEventListener(eventName, function () {
          fileLabel.classList.remove("is-dragging");
        });
      });

      fileLabel.addEventListener("drop", function (event) {
        if (event.dataTransfer.files.length) {
          fileInput.files = event.dataTransfer.files;
          fileInput.dispatchEvent(new Event("change", { bubbles: true }));
        }
      });
    }
  </script>
</body>
</html>
