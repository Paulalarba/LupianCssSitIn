@model CCSMonitoringSystem.Models.Student

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Syne:wght@700;800&display=swap" rel="stylesheet">

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    -webkit-touch-callout: none;
    -webkit-user-select: none;
    user-select: none;
    -webkit-user-select: text;
  }

  input, textarea, select {
    -webkit-user-select: text;
    user-select: text;
  }

  :root {
    --uc-navy: #003087;
    --uc-navy-dark: #001a4d;
    --uc-navy-light: #0d4298;
    --uc-gold: #FFB81C;
    --uc-gold-light: #ffc84d;
    --uc-gold-dark: #d9940f;
    --text-white: #ffffff;
    --text-light: #e8e8e8;
    --text-muted: #b0b0b0;
    --text-dark: #1a1a1a;
    --bg-dark: #0f0f23;
    --bg-form: #1a1a2e;
    --bg-input: #262641;
    --border-input: #3d3d5c;
    --focus-gold: rgba(255, 184, 28, 0.3);
    --success-color: #4ade80;
    --danger-color: #f87171;
  }

  html, body {
    margin: 0;
    padding: 0;
    height: 100%;
    width: 100%;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    overflow: hidden;
  }

  body {
    display: flex;
    flex-direction: column;
    position: absolute;
    inset: 0;
    background: url('https://images.unsplash.com/photo-1607237138185-eedd9c632b0b?w=1400&auto=format&fit=crop&q=80');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    filter: brightness(0.6) saturate(1.1);
  }

  body::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(0, 26, 77, 0.75) 0%,
      rgba(0, 48, 135, 0.65) 35%,
      rgba(13, 66, 152, 0.7) 100%
    );
    z-index: 0;
    pointer-events: none;
  }

  /* ════════════════════════════════════════════════════════════ */
  /* MAIN CONTAINER                                               */
  /* ════════════════════════════════════════════════════════════ */
  .auth-wrapper {
    display: flex;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    position: relative;
    z-index: 1;
  }

  /* ════════════════════════════════════════════════════════════ */
  /* HERO PANEL - LEFT                                            */
  /* ════════════════════════════════════════════════════════════ */
  .left-panel {
    flex: 1;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: clamp(2rem, 4vw, 4rem) clamp(2rem, 5vw, 3.5rem);
    min-height: 100vh;
    overflow: hidden;
  }

  .left-panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background: transparent;
    z-index: 0;
  }

  .left-panel::after {
    content: '';
    position: absolute;
    inset: 0;
    background: transparent;
    z-index: 1;
  }

  .left-panel > * {
    position: relative;
    z-index: 2;
  }

  /* Logo treatment with enhanced styling */
  .brand-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    background: rgba(255, 255, 255, 0.09);
    backdrop-filter: blur(20px);
    border: 1.5px solid rgba(255, 184, 28, 0.3);
    border-radius: 14px;
    padding: 0.8rem 1.3rem;
    width: fit-content;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
  }

  .brand-badge:hover {
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 184, 28, 0.5);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(255, 184, 28, 0.15);
  }

  .brand-badge .logo-icon {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, var(--uc-gold) 0%, var(--uc-gold-light) 100%);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Syne', serif;
    font-weight: 800;
    font-size: 0.68rem;
    color: var(--uc-navy-dark);
    line-height: 1;
    letter-spacing: -0.02em;
    box-shadow: 0 4px 16px rgba(255, 184, 28, 0.3);
  }

  .brand-badge .brand-name {
    font-family: 'Syne', serif;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text-white);
    letter-spacing: 0.02em;
  }

  .brand-badge .brand-sub {
    font-size: 0.62rem;
    font-weight: 600;
    color: var(--uc-gold);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* Hero content with enhanced typography */
  .hero-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2rem;
    animation: fadeInUp 0.8s ease-out 0.2s both;
  }

  @@keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .new-student-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, rgba(255, 184, 28, 0.15) 0%, rgba(255, 184, 28, 0.08) 100%);
    border: 1px solid rgba(255, 184, 28, 0.35);
    color: var(--uc-gold);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    padding: 0.5rem 1.1rem;
    border-radius: 24px;
    margin-bottom: 1.2rem;
    box-shadow: 0 4px 12px rgba(255, 184, 28, 0.1);
    width: fit-content;
  }

  .hero-content h1 {
    font-family: 'Syne', serif;
    font-size: clamp(2.4rem, 6vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    color: #ffffff;
    text-shadow: 0 4px 16px rgba(0, 0, 0, 0.7);
    letter-spacing: -0.02em;
    word-spacing: 0.05em;
  }

  .hero-content h1 .highlight {
    color: #FFD54F;
    display: block;
    background: linear-gradient(135deg, #FFD54F 0%, #FFEB3B 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-content p {
    font-size: clamp(1rem, 2.2vw, 1.1rem);
    line-height: 1.8;
    color: #ffffff;
    max-width: 480px;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.6);
    font-weight: 400;
    letter-spacing: 0.01em;
  }

  /* Footer on hero */
  .left-footer {
    font-size: 0.68rem;
    color: #FFD54F;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.4);
  }

  /* ════════════════════════════════════════════════════════════ */
  /* FORM PANEL - RIGHT                                           */
  /* ════════════════════════════════════════════════════════════ */
  .right-panel {
    width: clamp(350px, 100%, 440px);
    flex-shrink: 1;
    background: transparent;
    overflow-y: auto;
    overflow-x: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    min-height: 100vh;
    position: relative;
    min-width: 280px;
  }

  /* Decorative background elements */
  .right-panel::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(255, 184, 28, 0.08) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  /* Form wrapper with enhanced card effect */
  .form-box {
    width: 100%;
    max-width: clamp(300px, 90vw, 380px);
    background: rgba(15, 15, 35, 0.95);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 184, 28, 0.15);
    border-radius: 20px;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    box-shadow: 
      0 25px 50px rgba(0, 0, 0, 0.7),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    animation: slideInUp 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    position: relative;
    z-index: 1;
  }

  @@keyframes slideInUp {
    from {
      opacity: 0;
      transform: translateY(32px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* CREATE ACCOUNT badge */
  .page-badge {
    display: inline-block;
    background: linear-gradient(135deg, rgba(255, 184, 28, 0.15) 0%, rgba(255, 184, 28, 0.08) 100%);
    border: 1px solid rgba(255, 184, 28, 0.35);
    color: var(--uc-gold);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    padding: 0.5rem 1.1rem;
    border-radius: 24px;
    margin-bottom: 1.2rem;
    box-shadow: 0 4px 12px rgba(255, 184, 28, 0.1);
  }

  .form-title {
    font-family: 'Syne', serif;
    font-size: 2rem;
    font-weight: 800;
    color: #ffffff;
    line-height: 1.1;
    margin-bottom: 0.6rem;
    letter-spacing: -0.01em;
    background: linear-gradient(135deg, #ffffff 0%, #FFD54F 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .form-sub {
    font-size: 0.93rem;
    color: #e8e8e8;
    margin-bottom: 1.8rem;
    line-height: 1.6;
    font-weight: 400;
  }

  /* ── Form Grid ── */
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.85rem;
    margin-bottom: 1rem;
  }

  .form-grid.full { grid-template-columns: 1fr; }

  /* ── Form Fields ── */
  .field-group { 
    margin-bottom: 1.2rem;
    position: relative;
    animation: fadeIn 0.4s ease-out both;
  }

  @@keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .field-label {
    display: flex;
    align-items: center;
    font-size: 0.76rem;
    font-weight: 700;
    color: #e8e8e8;
    margin-bottom: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    transition: color 0.3s ease;
  }

  .field-label:hover {
    color: var(--uc-gold);
  }

  .field-label .optional-badge {
    font-size: 0.65rem;
    color: #a0a0a0;
    font-weight: 400;
    text-transform: lowercase;
    letter-spacing: 0;
    margin-left: 6px;
    transition: color 0.3s ease;
  }

  .field-label:hover .optional-badge {
    color: #d0d0d0;
  }

  .input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .input-wrap input,
  .input-wrap select {
    width: 100%;
    background: linear-gradient(135deg, rgba(38, 38, 65, 0.95) 0%, rgba(61, 61, 92, 0.7) 100%);
    border: 1.5px solid rgba(255, 184, 28, 0.15);
    border-radius: 10px;
    color: #ffffff;
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    padding: 1rem 1.2rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    backdrop-filter: blur(4px);
    position: relative;
    z-index: 1;
  }

  .input-wrap input::placeholder,
  .input-wrap select::placeholder {
    color: rgba(224, 224, 224, 0.5);
  }

  .input-wrap input:focus,
  .input-wrap select:focus {
    outline: none;
    border-color: var(--uc-gold);
    background: linear-gradient(135deg, rgba(38, 38, 65, 1) 0%, rgba(61, 61, 92, 0.7) 100%);
    box-shadow: 
      0 0 0 4px var(--focus-gold),
      0 0 20px rgba(255, 184, 28, 0.2),
      inset 0 1px 3px rgba(0, 0, 0, 0.3);
  }

  .input-wrap input:hover:not(:focus),
  .input-wrap select:hover:not(:focus) {
    border-color: rgba(255, 184, 28, 0.25);
    background: linear-gradient(135deg, rgba(38, 38, 65, 0.95) 0%, rgba(61, 61, 92, 0.6) 100%);
  }

  /* Field validation spans */
  .val-error {
    display: block;
    margin-top: 0.35rem;
    color: #f87171;
    font-size: 0.76rem;
    animation: slideDown 0.3s ease-out;
    font-weight: 500;
  }

  @@keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-5px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── File Upload ── */
  .file-upload-wrapper {
    margin-bottom: 0.5rem;
  }

  .file-upload-label {
    display: block;
    padding: 1.2rem;
    border: 1.5px dashed rgba(255, 184, 28, 0.2);
    border-radius: 10px;
    text-align: center;
    background: linear-gradient(135deg, rgba(38, 38, 65, 0.8) 0%, rgba(61, 61, 92, 0.6) 100%);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .file-upload-label:hover {
    border-color: rgba(255, 184, 28, 0.5);
    background: linear-gradient(135deg, rgba(38, 38, 65, 0.95) 0%, rgba(61, 61, 92, 0.7) 100%);
    box-shadow: 0 0 20px rgba(255, 184, 28, 0.15);
  }

  .file-upload-label input { display: none; }

  .file-upload-text {
    color: #d0d0d0;
    font-size: 0.87rem;
  }

  .file-name {
    color: var(--uc-gold);
    font-weight: 600;
    margin-top: 0.4rem;
    font-size: 0.82rem;
  }

  /* ── Submit Button ── */
  .btn-register {
    width: 100%;
    padding: 1.1rem;
    background: linear-gradient(135deg, var(--uc-gold) 0%, var(--uc-gold-light) 100%);
    border: none;
    border-radius: 12px;
    color: var(--uc-navy-dark);
    font-family: 'Inter', sans-serif;
    font-size: 0.96rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 10px 30px rgba(255, 184, 28, 0.3);
    position: relative;
    overflow: hidden;
    margin-top: 0.5rem;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
  }

  .btn-register::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.3) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .btn-register:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(255, 184, 28, 0.4);
  }

  .btn-register:hover::before {
    opacity: 1;
  }

  .btn-register:active {
    transform: translateY(-1px);
    box-shadow: 0 8px 20px rgba(255, 184, 28, 0.3);
  }

  .btn-register:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  /* ── Alerts ── */
  .alert-success-dark {
    background: rgba(76, 222, 128, 0.12);
    border: 1px solid rgba(76, 222, 128, 0.35);
    color: #86efac;
    border-radius: 10px;
    padding: 1rem 1.2rem;
    font-size: 0.87rem;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
    backdrop-filter: blur(4px);
    box-shadow: 0 0 20px rgba(76, 222, 128, 0.1);
  }

  .alert-danger-dark {
    background: rgba(248, 113, 113, 0.12);
    border: 1px solid rgba(248, 113, 113, 0.35);
    color: #fca5a5;
    border-radius: 10px;
    padding: 1rem 1.2rem;
    font-size: 0.87rem;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
    backdrop-filter: blur(4px);
    box-shadow: 0 0 20px rgba(248, 113, 113, 0.1);
  }

  .validation-summary {
    background: rgba(248, 113, 113, 0.12);
    border: 1px solid rgba(248, 113, 113, 0.35);
    color: #fca5a5;
    border-radius: 10px;
    padding: 1rem 1.2rem;
    font-size: 0.87rem;
    margin-bottom: 1.5rem;
    backdrop-filter: blur(4px);
    box-shadow: 0 0 20px rgba(248, 113, 113, 0.1);
  }

  .validation-summary ul { margin: 0; padding-left: 1.4rem; }
  .validation-summary li { margin-bottom: 0.35rem; }

  .validation-summary strong {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  /* ── Divider ── */
  .or-divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: #a0a0a0;
    margin-bottom: 1.2rem;
  }

  .or-divider span {
    flex: 1;
    height: 1px;
    background: rgba(255, 184, 28, 0.15);
    display: block;
  }

  /* ── Login prompt ── */
  .login-prompt {
    text-align: center;
    font-size: 0.93rem;
    color: #d0d0d0;
    margin-bottom: 1.8rem;
  }

  .login-prompt a {
    color: var(--uc-gold);
    text-decoration: none;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .login-prompt a:hover {
    color: var(--uc-gold-light);
  }

  /* ── Footer links ── */
  .page-footer-links {
    display: flex;
    justify-content: center;
    gap: 1.4rem;
    margin-top: 1rem;
    font-size: 0.72rem;
    color: #b0b0b0;
  }

  .page-footer-links a {
    color: #b0b0b0;
    text-decoration: none;
    transition: all 0.3s ease;
    font-weight: 500;
  }

  .page-footer-links a:hover {
    color: var(--uc-gold);
  }

  /* ── Responsive ── */
  @@media (max-width: 1200px) {
    .left-panel {
      padding: clamp(1.5rem, 3vw, 3rem) clamp(1.5rem, 4vw, 2.5rem);
    }

    .hero-content h1 {
      font-size: clamp(2rem, 5vw, 2.8rem);
    }

    .right-panel {
      width: clamp(320px, 95vw, 400px);
    }

    .form-box {
      max-width: clamp(280px, 90vw, 360px);
    }
  }

  @@media (max-width: 1024px) {
    .left-panel {
      display: none;
    }

    .right-panel {
      width: 100%;
      background: transparent;
      min-width: unset;
    }

    .auth-wrapper {
      justify-content: center;
    }
  }

  @@media (max-width: 768px) {
    .auth-wrapper {
      flex-direction: column;
    }

    .right-panel {
      width: 100%;
      height: 100vh;
      padding: clamp(1.5rem, 3vw, 2rem);
    }

    .form-box {
      max-width: 100%;
      padding: clamp(1.5rem, 3vw, 2rem);
    }

    .form-title {
      font-size: 1.7rem;
    }

    .form-grid {
      grid-template-columns: 1fr;
    }
  }

  @@media (max-width: 480px) {
    .right-panel {
      padding: clamp(1rem, 2vw, 1.5rem);
    }

    .form-box {
      padding: clamp(1.25rem, 2.5vw, 1.5rem);
    }

    .form-title {
      font-size: 1.5rem;
    }

    .page-badge {
      font-size: 0.68rem;
      padding: 0.45rem 1rem;
    }

    .btn-register {
      font-size: 0.92rem;
      padding: 1rem;
    }
  }

  @@media (max-width: 350px) or (max-height: 600px) {
    .right-panel {
      padding: 1rem;
      min-height: auto;
    }

    .form-box {
      padding: 1.25rem;
    }

    .form-title {
      font-size: 1.3rem;
    }
  }

  /* Scrollbar styling */
  .right-panel::-webkit-scrollbar {
    width: 8px;
  }

  .right-panel::-webkit-scrollbar-track {
    background: transparent;
  }

  .right-panel::-webkit-scrollbar-thumb {
    background: linear-gradient(180deg, rgba(255, 184, 28, 0.3) 0%, rgba(255, 184, 28, 0.15) 100%);
    border-radius: 4px;
  }

  .right-panel::-webkit-scrollbar-thumb:hover {
    background: linear-gradient(180deg, rgba(255, 184, 28, 0.4) 0%, rgba(255, 184, 28, 0.25) 100%);
  }
</style>

<div class="auth-wrapper">

  <!-- LEFT PANEL -->
  <div class="left-panel">
    <!-- Brand -->
    <div class="brand-badge">
      <div class="logo-icon">UC<br>CCS</div>
      <div>
        <span class="brand-name">UC CCS</span>
        <span class="brand-sub">Portal</span>
      </div>
    </div>

    <!-- Hero -->
    <div class="hero-content">
      <div>
        <div class="new-student-badge">★ New Student Registration</div>
        <h1>Join the CCS<span class="highlight">Community</span></h1>
        <p>Create your account and unlock access to courses, faculty, announcements, and the full suite of CCS academic tools — all in one place.</p>
      </div>
    </div>

    <div class="left-footer">© University of Cebu – College of Computer Studies</div>
  </div>

  <!-- RIGHT PANEL -->
  <div class="right-panel">
    <div class="form-box">

      <div class="page-badge">✦ Create Account</div>
      <h2 class="form-title">Join CCS Portal</h2>
      <div class="form-sub">Fill in your details to get started with your academic journey.</div>

      @if (ViewData.ModelState.IsValid == false)
      {
        <div class="validation-summary">
          <strong>Please correct the following errors:</strong>
          <ul>
            @foreach (var modelState in ViewData.ModelState.Values)
            {
              @foreach (var error in modelState.Errors)
              {
                <li>@error.ErrorMessage</li>
