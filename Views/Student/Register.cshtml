<script>
  // File name display
  document.getElementById('profilePictureFile').addEventListener('change', function(e) {
    const fileName = document.getElementById('fileName');
    if (e.target.files.length > 0) {
      fileName.textContent = '✓ ' + e.target.files[0].name;
    } else {
      fileName.textContent = '';
    }
  });

  // Drag and drop
  const fileLabel = document.querySelector('.file-upload-label');
  ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(ev => {
    fileLabel.addEventListener(ev, e => { e.preventDefault(); e.stopPropagation(); });
  });
  ['dragenter', 'dragover'].forEach(ev => {
    fileLabel.addEventListener(ev, () => {
      fileLabel.style.borderColor = 'rgba(255, 184, 28, 0.5)';
      fileLabel.style.background = 'linear-gradient(135deg, rgba(38, 38, 65, 0.95) 0%, rgba(61, 61, 92, 0.7) 100%)';
    });
  });
  ['dragleave', 'drop'].forEach(ev => {
    fileLabel.addEventListener(ev, () => {
      fileLabel.style.borderColor = 'rgba(255, 184, 28, 0.2)';
      fileLabel.style.background = 'linear-gradient(135deg, rgba(38, 38, 65, 0.8) 0%, rgba(61, 61, 92, 0.6) 100%)';
    });
  });
  fileLabel.addEventListener('drop', e => {
    const files = e.dataTransfer.files;
    document.getElementById('profilePictureFile').files = files;
    document.getElementById('profilePictureFile').dispatchEvent(new Event('change', { bubbles: true }));
  });
</script>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
